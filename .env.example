# === BANCO DE DADOS ===
DATABASE_URL="postgresql://imoveis:imoveis123@localhost:5432/imoveis"

# === REDIS / FILA ===
REDIS_URL="redis://localhost:6379"

# === SESSÃO DO BROWSER ===
# Diretório onde o perfil do Chromium será salvo
FB_SESSION_DIR="./data/sessions/profile1"

# === GRUPOS MONITORADOS (separados por vírgula) ===
# Adicione via painel web, mas pode pré-configurar aqui
GROUPS=""

# === CONFIGURAÇÕES DE COLETA ===
# Quanto tempo coletar por sessão (em minutos)
SESSION_DURATION_MIN=20
SESSION_DURATION_MAX=40

# Máximo de dias de histórico para coletar
MAX_POST_AGE_DAYS=365

# Palavras-chave para busca histórica
KEYWORDS="aluguel,vendo casa,apartamento,lote,terreno,imóvel,financiamento,corretor"

# === SERVIDOR API ===
API_PORT=3001
FRONTEND_PORT=5173
